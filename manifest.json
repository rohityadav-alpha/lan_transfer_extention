{
  "manifest_version": 3,
  "name": "LAN File Transfer",
  "version": "1.0.0",
  "description": "Transfer files directly between browsers on the same local network — no internet, no cloud, no USB.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "LAN File Transfer"
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "permissions": [
    "storage",
    "sidePanel",
    "notifications"
  ],
  "host_permissions": [
    "http://*/*"
  ]
}
